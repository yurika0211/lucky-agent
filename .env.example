# ============================================================
# LuckyHarness environment example
# Copy to .env and fill secrets:
#   cp .env.example .env
#
# Usage notes:
# - docker compose reads .env for variable substitution.
# - Source runs can load it with:
#     set -a; . ./.env; set +a
# - Docker prod entrypoint maps many LH_* variables into config.json.
# - Source runs directly read only variables explicitly marked as runtime env.
# ============================================================

# ============================================================
# Runtime / Docker Compose
# ============================================================

# Timezone used by docker-compose.yml / docker-compose.prod.yml.
TZ=Asia/Shanghai

# Image and exposed ports used by docker-compose.prod.yml.
LH_IMAGE=ghcr.io/yurika0211/luckyharness:latest
LH_PORT=9090
LH_NAPCAT_PORT=6701

# LuckyHarness runtime home.
# Source mode uses $HOME/.luckyharness. Docker images set HOME=/var/lib/luckyharness.
# Do not blindly source this in your interactive shell unless you want HOME changed.
# HOME=/var/lib/luckyharness

# Historical/deployment hint only. Current source runtime does not use LH_HOME directly.
LH_HOME=/var/lib/luckyharness


# ============================================================
# LLM provider
# Docker prod entrypoint maps these into config.json.
# ============================================================

# Provider: openai | anthropic | ollama | openrouter
LH_PROVIDER=openai

# API key. Leave empty for ollama/local models.
LH_API_KEY=

# OpenAI-compatible API base URL.
# LH_API_BASE=https://api.openai.com/v1

# Model name.
LH_MODEL=gpt-5.4-mini

# Context and sampling.
LH_MAX_TOKENS=131072
LH_TEMPERATURE=0.7

# Optional fallback chain JSON.
# Example:
# LH_FALLBACKS=[{"provider":"anthropic","api_key":"sk-ant-xxx","model":"claude-sonnet-4-20250514"}]
# LH_FALLBACKS=


# ============================================================
# HTTP API server
# Docker prod entrypoint maps these into config.json.
# ============================================================

LH_API_ADDR=:9090

# Comma-separated API key whitelist. Empty = no API-key auth.
# LH_API_KEYS=

LH_RATE_LIMIT=60

# CORS and metrics.
LH_ENABLE_CORS=true
LH_CORS_ORIGINS=*
# LH_METRICS_ADDR=:9091

# Logging.
LH_LOG_LEVEL=info
LH_LOG_FORMAT=json


# ============================================================
# Message gateway common
# Docker prod entrypoint maps these into config.json.
# ============================================================

# Platform: telegram | qqofficial | napcat | weixin | openclawweixin
LH_MSG_GATEWAY_PLATFORM=

# Start all configured gateways in one process.
LH_MSG_GATEWAY_START_ALL=false


# ============================================================
# Telegram gateway
# Docker prod entrypoint maps these into config.json.
# ============================================================

LH_TELEGRAM_TOKEN=

# Optional Telegram API proxy: http://host:port | socks5://host:port
# LH_TELEGRAM_PROXY=

# Whole chat round timeout in seconds.
LH_TELEGRAM_CHAT_TIMEOUT_SECONDS=600

# Progress display controls.
LH_TELEGRAM_PROGRESS_AS_MESSAGES=true
LH_TELEGRAM_PROGRESS_AS_NATURAL_LANGUAGE=false
LH_TELEGRAM_PROGRESS_SUMMARY_WITH_LLM=false
LH_TELEGRAM_SHOW_TOOL_DETAILS_IN_RESULT=false

# Note: Telegram chat/user allowlists are not currently wired as LH_* env vars.
# Configure allowlists in code/config when that support is added.


# ============================================================
# QQ Official gateway
# Current supported path: config.json or CLI flags, not LH_* env vars.
# Examples:
#   lh config set msg_gateway.qqofficial.app_id your-app-id
#   lh config set msg_gateway.qqofficial.app_secret your-app-secret
#   lh config set msg_gateway.qqofficial.sandbox false
#   lh msg-gateway start --platform qqofficial
# Or:
#   lh msg-gateway start --platform qqofficial --qq-appid your-app-id --qq-appsecret your-app-secret
# ============================================================


# ============================================================
# NapCat / OneBot v11 reverse WebSocket gateway
# Docker prod entrypoint maps these into config.json.
# ============================================================

LH_NAPCAT_LISTEN_ADDR=127.0.0.1:6701
LH_NAPCAT_PATH=/onebot/v11/ws

# Must match NapCat OneBot access_token when enabled.
# LH_NAPCAT_ACCESS_TOKEN=

# Comma-separated whitelist. Chat values may be raw id or private:<qq> / group:<group>.
# LH_NAPCAT_ALLOWED_CHATS=
# LH_NAPCAT_ALLOWED_USERS=

# Remove leading @bot mention from group messages.
LH_NAPCAT_REMOVE_AT=true

# Group trigger mode: mention | all
LH_NAPCAT_GROUP_TRIGGER_MODE=mention


# ============================================================
# Weixin iLink gateway
# Docker prod entrypoint maps these into config.json.
# ============================================================

LH_WEIXIN_TOKEN=
LH_WEIXIN_ACCOUNT_ID=
LH_WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com

# Private chat policy: open | disabled | allowlist
LH_WEIXIN_DM_POLICY=open

# Group policy: disabled | open | allowlist
LH_WEIXIN_GROUP_POLICY=disabled

# Comma-separated user ids.
# LH_WEIXIN_ALLOWED_USERS=
# LH_WEIXIN_GROUP_ALLOWED_USERS=

LH_WEIXIN_SPLIT_MULTILINE_MESSAGES=true
LH_WEIXIN_POLL_TIMEOUT_MS=35000
LH_WEIXIN_SEND_CHUNK_DELAY_MS=350


# ============================================================
# OpenClaw Weixin runtime env
# These are read directly by the OpenClaw adapter.
# ============================================================

# OPENCLAW_STATE_DIR=/var/lib/luckyharness/openclaw
# CLAWDBOT_STATE_DIR=/var/lib/luckyharness/openclaw


# ============================================================
# Web search and web fetch
# Source runtime supports LH_WEB_SEARCH_* through applyWebSearchEnv().
# Tool/search package also supports LH_SEARCH_* compatibility vars.
# ============================================================

# Primary web_search config: brave | ddgs | searxng | exa
LH_WEB_SEARCH_PROVIDER=brave
LH_WEB_SEARCH_MAX_RESULTS=5
# LH_WEB_SEARCH_API_KEY=
# LH_WEB_SEARCH_BASE_URL=
# LH_WEB_SEARCH_PROXY=

# Common provider-specific aliases.
# BRAVE_API_KEY=
# EXA_API_KEY=
# SEARXNG_BASE_URL=
# JINA_API_KEY=

# Compatibility search router envs.
# LH_SEARCH_PROVIDER=ddgs
# LH_SEARCH_BRAVE_KEY=
# LH_SEARCH_SEARXNG_URL=
# LH_SEARCH_EXA_KEY=
# LH_SEARCH_JINA_KEY=
# LH_SEARCH_PROXY=
# LH_SEARCH_MAX_RESULTS=10
# LH_SEARCH_CACHE_TTL_SECONDS=300


# ============================================================
# OpenCLI website extraction
# Source runtime supports LH_OPENCLI_* through applyOpenCLIEnv().
# ============================================================

LH_OPENCLI_ENABLED=true
LH_OPENCLI_COMMAND=opencli
LH_OPENCLI_ARGS=web,read,--url,{url},--stdout,true,--download-images,false,-f,md
LH_OPENCLI_TIMEOUT_SECONDS=20
LH_OPENCLI_MAX_CHARS=50000
LH_OPENCLI_FALLBACK_TO_WEB_FETCH=true


# ============================================================
# Embedding / RAG
# Runtime reads these directly when embedding/RAG is enabled.
# ============================================================

# Embedding provider compatible with OpenAI-style embedding APIs.
# EMBEDDING_MODEL_KEY=
# EMBEDDING_MODEL_NAME=
# EMBEDDING_MODEL_URL=
# EMBEDDING_MODEL_DIMENSION=

# Embedding runtime tuning.
# EMBEDDING_BATCH_SIZE=16
# EMBEDDING_MODEL_TIMEOUT_SECONDS=30
# EMBEDDING_MODEL_MAX_RETRIES=3

# RAG behavior.
LH_RAG_INDEX_FINAL_ANSWERS=false
LH_RAG_INCLUDE_GENERATED=false
# LH_RAG_RETRIEVAL_LOG=/var/lib/luckyharness/logs/rag-retrieval.jsonl


# ============================================================
# Telegram meme assets
# Runtime reads these directly.
# ============================================================

# Directory containing image files used as random Telegram meme replies.
# LH_TG_MEME_DIR=/var/lib/luckyharness/memes
LH_TG_MEME_PROBABILITY=0
LH_TG_MEME_COOLDOWN_SECONDS=300


# ============================================================
# Telemetry
# Runtime reads these directly in the HTTP server.
# ============================================================

LH_TELEMETRY_ENABLED=false

# Exporter: stdout | otlp
LH_TELEMETRY_EXPORTER=stdout

# Used when LH_TELEMETRY_EXPORTER=otlp.
# LH_TELEMETRY_OTLP_ENDPOINT=127.0.0.1:4317

LH_TELEMETRY_SAMPLE_RATE=1.0


# ============================================================
# Agent / context / diagnostics
# Runtime reads these directly.
# ============================================================

# Enable/disable intent-based tool gating: true | false
# LH_TOOL_INTENT_GATING=true

# Override injected manual/context files.
# LUCKYHARNESS_MANUAL_FILE=/path/to/LUCKYHARNESS_AGENT_MANUAL.md
# LUCKYHARNESS_AGENTS_FILE=/path/to/AGENTS.md

# Save upstream provider request/response captures for debugging.
# LH_UPSTREAM_CAPTURE_DIR=/var/lib/luckyharness/logs/upstream

# Include custom dashboard static assets.
# LH_DASHBOARD_STATIC=/path/to/dashboard/static

# TUI/UI workspace discovery.
# LH_TUI_DIR=/path/to/luckyharness/UI
# LH_UI_DIR=/path/to/luckyharness/UI

# Live search tests only; keep disabled in normal deployments.
LH_RUN_LIVE_SEARCH_TESTS=0


# ============================================================
# SOUL / prompt files
# Docker prod entrypoint maps LH_SOUL_PATH into config.json.
# ============================================================

# LH_SOUL_PATH=/var/lib/luckyharness/SOUL.md
